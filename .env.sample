# ──────────────────────────────────────────────
#  Variables communes – change selon l’environnement
# ──────────────────────────────────────────────

# ─── Pour développement local (sans docker) ───
# DB_HOST=localhost
# DB_PORT=5432
# POSTGRES_USER=nexa_user
# POSTGRES_PASSWORD=devpass123
# POSTGRES_DB=nexa_dev

# ─── Pour Docker (dev ET prod) ───
POSTGRES_USER=nexa_user
POSTGRES_PASSWORD=supersecurepass2026!
POSTGRES_DB=nexa

# ─── Utilisé par Sequelize / backend ───
#   → en docker : db:5432
#   → en local : localhost:5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST:-db}:${DB_PORT:-5432}/${POSTGRES_DB}

# Autres variables obligatoires
NODE_ENV=development          # change en production sur le serveur
PORT=4001
JWT_SECRET=ton-super-secret-jwt-au-moins-64-caracteres
JWT_EXPIRES_IN=2h
BCRYPT_SALT=12                # 12 est un bon compromis 2025

# Frontend / reverse proxy
BACKEND_URL=http://localhost:4001     # pour dev local
FRONTEND_URL=http://localhost:3000

# Prod / hosting
# BACKEND_URL=https://api.mon-domaine.com
# FRONTEND_URL=https://mon-domaine.com

# Cloudinary (ne jamais commiter les vrais)
CLOUDINARY_CLOUD_NAME=xxxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email (optionnel)
MAIL_USER=sioudranim@gmail.com
MAIL_PASS=app-specific-password
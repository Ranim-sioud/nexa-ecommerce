# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nexa_user
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=nexa

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_EXPIRES_IN=15m
BCRYPT_SALT=12
FRONTEND_URL=https://nexa-tn.com

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_NOM=Admin
ADMIN_EMAIL=admin@nexa-tn.com
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_TELEPHONE=20000000
ADMIN_VILLE=Tunis
ADMIN_GOUVERNORAT=Tunis
ADMIN_ADRESSE=Tunis, Tunisie

# ── Frontend build ────────────────────────────────────────────────────────────
# The URL the browser uses to reach the backend API (no trailing slash)
VITE_API_URL=https://nexa-tn.com/api

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
